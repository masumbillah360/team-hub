{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2024",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../packages/database/generated/prisma"
  ],
  "exclude": [
    "node_modules"
  ]
}